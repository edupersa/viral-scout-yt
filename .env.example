# ViralScout Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://viralscout:viralscout@localhost:5432/viralscout
DATABASE_URL_SYNC=postgresql://viralscout:viralscout@localhost:5432/viralscout
POSTGRES_USER=viralscout
POSTGRES_PASSWORD=viralscout
POSTGRES_DB=viralscout

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── YouTube Data API v3 ───
# Get yours at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your GCP project first
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Google Gemini AI ───
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Auth / JWT ───
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_64_char_hex_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── App ───
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
API_V1_PREFIX=/api/v1

# ─── Rate Limiting ───
YOUTUBE_DAILY_QUOTA=10000
MAX_KEYWORDS_PER_REQUEST=12
MAX_SEARCH_RESULTS=50
